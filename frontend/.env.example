# Optional when the admin API is hosted separately from the Vite dev server.
VITE_API_BASE_URL=http://localhost:8080
# Public Supabase browser auth configuration for the GitHub Pages login flow.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_APP_BUILD_ID=dev-local
# Optional comma-separated allowlist for the admin SPA.
VITE_ALLOWED_ADMIN_EMAILS=admin@example.com
