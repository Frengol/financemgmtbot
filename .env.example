# Backend local configuration
PORT=8080

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SECRET_TOKEN=your-telegram-webhook-secret

# Supabase backend/service access
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# AI providers
DEEPSEEK_API_KEY=your-deepseek-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Admin protection
SUPABASE_ADMIN_EMAILS=admin@example.com
# Optional alternative to email allowlist
SUPABASE_ADMIN_USER_IDS=

# Frontend origins allowed to call the backend
# In Cloud Run production, this must include the published Pages origin (for example https://frengol.github.io)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,https://admin.example.com

# Public auth URLs used by the GitHub Pages login flow
# In Cloud Run production, this must point to the published Pages base URL
FRONTEND_PUBLIC_URL=https://admin.example.com/

# Optional dev/test flags
# Keep both flags false in Cloud Run production
ALLOW_LOCAL_DEV_AUTH=false
AUTH_TEST_MODE=false

# Optional encrypted pending-payload key
DATA_ENCRYPTION_KEY=
