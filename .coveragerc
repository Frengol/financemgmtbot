[run]
branch = True
relative_files = True
source =
    admin_api
    ai_service
    config
    core_logic
    db_repository
    handlers
    main
    security
    telegram_service
    utils
omit =
    test_*
    */test_*
    */__pycache__/*
    */dist/*
    .github/*
    frontend/*
    supabase/migrations/*

[report]
show_missing = True
skip_covered = False
precision = 2
fail_under = 90
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
